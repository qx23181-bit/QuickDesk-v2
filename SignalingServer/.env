# ========== 服务器配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ========== PostgreSQL 数据库配置（远程数据库） ==========
DB_HOST=85.137.244.152
DB_PORT=35432
DB_USER=postgres
DB_PASSWORD=2SaDLL2eZBpEBFhT
DB_NAME=werppt

# ========== Redis 配置（部署在 192.168.50.128） ==========
REDIS_HOST=85.137.244.152
REDIS_PORT=26739
REDIS_PASSWORD=3pAyPLnkXmFyiwhr

# ========== ICE 配置（用于 WebRTC 连接） ==========
# TURN 服务器地址（多个用逗号分隔）
TURN_URLS=turn:turn.quickcoder.cc:3478

# coturn 的 use-auth-secret 共享密钥（必须和 coturn 配置中的 static-auth-secret 一致）
TURN_AUTH_SECRET=xxxxxxx

# TURN 凭据有效时间（秒），默认 86400（24小时）
TURN_CREDENTIAL_TTL=86400

# STUN 服务器（可选，Qt 端已有内置 STUN，这里可以额外添加）
STUN_URLS=stun:stun.quickcoder.cc:3478

# ========== 管理员账号（用于管理界面登录） ==========
#ADMIN_USER=admin
#ADMIN_PASSWORD=admin123

# ========== API Key（用于客户端身份验证） ==========
# 空值 = 禁用，任何客户端都可以连接
# 设置此值可仅允许官方客户端连接
# 客户端必须通过 X-API-Key 请求头或 api_key 查询参数发送此密钥
API_KEY=

# ========== 允许的源（用于 WebClient） ==========
# 逗号分隔的允许访问的源地址，空值 = 禁用
# 浏览器会自动发送 Origin 请求头，JavaScript 无法伪造
# 只有从这些源加载的页面才能访问信令服务器
# 示例：https://web.quickdesk.cc,https://quickdesk.example.com
ALLOWED_ORIGINS=